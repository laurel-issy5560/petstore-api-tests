          "name": "CreatWith List",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = pm.response.json();\r",
                  "pm.test(\"status code is 200\", function(){\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "pm.test(\"response time is less than 2000ms\", function (){\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "pm.test(\"response is an object\", function (){\r",
                  "    pm.expect(response).to.be.an(\"object\");\r",
                  "});\r",
                  "pm.test(\"response to contain code\", function (){ \r",
                  "    pm.expect(response).to.have.property(\"code\");\r",
                  "});\r",
                  "pm.test(\"type field is a string\", function () {\r",
                  "    pm.expect(response.type).to.be.a(\"string\");\r",
                  "});\r",
                  "pm.test(\"type is unknown\", function (){  \r",
                  "    pm.expect(response.type).to.eql(\"unknown\");\r",
                  "});\r",
                  "pm.test(\"message field exist\", function (){ \r",
                  "    pm.expect(response.message).to.exist;\r",
                  "});\r",
                  "pm.test(\"message field is not empty\", function (){\r",
                  "    pm.expect(response.message).to.not.be.empty;\r",
                  "});"
